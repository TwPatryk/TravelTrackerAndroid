<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image and Overlay -->
    <ImageView
        android:id="@+id/entry_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:importantForAccessibility="no"/>

    <View
        android:id="@+id/entry_background_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Tytuł -->
        <EditText
            android:id="@+id/entry_title_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Entry Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Tagi -->
        <EditText
            android:id="@+id/entry_tags_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tags (comma separated, e.g. nature, summer, trip)"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Zawartość (Notatki i Zdjęcia) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/items_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="true"/>

        <!-- Przyciski dodawania -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_add_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Note"
                android:backgroundTint="@color/primary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_add_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Photo"
                android:backgroundTint="@color/primary"
                android:layout_margin="8dp"/>

            <Button
                android:id="@+id/btn_add_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Pin"
                android:backgroundTint="@color/primary"
                android:layout_margin="8dp"/>
        </LinearLayout>

        <!-- Przyciski -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_save_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save"
                android:backgroundTint="@color/primary_dark"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_cancel_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:backgroundTint="@color/gray"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btn_edit_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change Background Settings"
            android:layout_marginTop="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
</FrameLayout>
