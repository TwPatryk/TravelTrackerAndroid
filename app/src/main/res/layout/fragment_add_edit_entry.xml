<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Background Image and Overlay -->
    <ImageView
        android:id="@+id/entry_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:fitsSystemWindows="false"
        android:importantForAccessibility="no"/>

    <View
        android:id="@+id/entry_background_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:fitsSystemWindows="false"
        android:visibility="gone"/>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/edit_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="4dp"
        android:background="#00000000"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Tytuł -->
        <EditText
            android:id="@+id/entry_title_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Entry Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Tagi -->
        <EditText
            android:id="@+id/entry_tags_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tags (comma separated, e.g. nature, summer, trip)"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Zawartość (Notatki i Zdjęcia) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/items_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="true"/>

        <!-- Przyciski dodawania -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_note"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Note"
                android:textSize="10sp"
                android:padding="4dp"
                app:icon="@drawable/ic_add"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                android:layout_marginEnd="4dp"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_photo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Photo"
                android:textSize="10sp"
                android:padding="4dp"
                app:icon="@drawable/ic_add"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                android:layout_marginEnd="4dp"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_pin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pin"
                android:textSize="10sp"
                android:padding="4dp"
                app:icon="@drawable/ic_add"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                android:layout_marginEnd="4dp"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_track"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Track"
                android:textSize="10sp"
                android:padding="4dp"
                app:icon="@drawable/ic_add"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"/>
        </LinearLayout>

        <!-- Przyciski -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_save_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_cancel_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:backgroundTint="@color/gray"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Change Background Settings"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.Icon"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_items_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Items Background"
                android:layout_marginTop="8dp"
                android:textColor="@android:color/white"
                app:iconTint="@android:color/white"
                style="@style/Widget.MaterialComponents.Button.Icon"/>
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
</FrameLayout>
