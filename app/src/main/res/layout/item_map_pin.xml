<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_drag_handle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_drag_handle"
            android:padding="4dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Drag to reorder"
            app:tint="@color/gray"
            android:alpha="0.6"/>

        <ImageView
            android:id="@+id/iv_pin_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="@color/primary"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <EditText
                android:id="@+id/pin_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Location Name"
                android:textSize="14sp"
                android:background="@null"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/pin_coords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0.0, 0.0"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:paddingStart="4dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_open_map"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_directions"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/primary"
            android:contentDescription="Open in Maps"/>

        <ImageButton
            android:id="@+id/btn_delete_pin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/delete_red"
            android:contentDescription="Delete pin"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>